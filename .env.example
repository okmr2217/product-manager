# DB
# Transactionモードプーラー（通常クエリ用、サーバーレス向け、ポート6543）
DATABASE_URL="postgresql://[user].[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# ダイレクト接続（マイグレーション用、poolerを経由しない）
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

